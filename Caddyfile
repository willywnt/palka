# Caddy auto-provisions and renews TLS for $DOMAIN via Let's Encrypt.
# Requirements: a DNS A/AAAA record for $DOMAIN → this server's IP, and ports
# 80 + 443 reachable. WebSocket upgrades (Socket.IO at /api/socket) are proxied
# transparently — no extra config needed.
#
# $DOMAIN is read from the caddy container's environment (set in docker-compose.prod.yml).

{$DOMAIN} {
	encode zstd gzip
	reverse_proxy web:3000
}
