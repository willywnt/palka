# =============================================================================
# Palka — Next.js client environment (public, embedded in browser bundle)
# Copy to apps/web/.env.local
# =============================================================================

# Desktop browser — use https://localhost when DEV_HTTPS=true (phone camera needs HTTPS on LAN)
NEXT_PUBLIC_APP_URL=https://localhost:3000
NEXT_PUBLIC_APP_NAME=Palka

# Mobile scanner / QR — your PC LAN IP (ipconfig → IPv4), must be https://
# NEXT_PUBLIC_PAIRING_URL=https://192.168.1.10:3000
# PAIRING_LAN_HOST=192.168.1.10

# Realtime pairing Socket.IO server. Leave UNSET in local dev AND on the VPS — the
# web container runs the custom `server.ts`, so the client uses the same origin.
# Only set this if you split the Socket.IO server onto a SEPARATE always-on host
# (for horizontal scaling); point it at that host's HTTPS/WSS URL. Cross-origin auth
# uses token-in-handshake, so no shared cookie domain is required.
# NEXT_PUBLIC_SOCKET_URL=https://socket.example.com

# Mobile-scanner feature flag. Defaults: ON in local dev, OFF in production
# (the feature needs the always-on socket host above). Set to true once that
# host is deployed to surface the "connect mobile scanner" UI in production.
# NEXT_PUBLIC_ENABLE_MOBILE_SCANNER=true

# Dev server (pnpm dev:web) — true enables self-signed HTTPS on port 3000
DEV_HTTPS=true

# Server-only variables live in the monorepo root .env file.
# Next.js also reads apps/web/.env.local — copy DATABASE_URL, AUTH_SECRET,
# R2_*, REDIS_URL, and other server vars here for local dev convenience.
#
# Auth (desktop): keep localhost when developing on this PC
# AUTH_URL=http://localhost:3000
# NEXTAUTH_URL=http://localhost:3000
#
# See docs/environment.md for the full variable reference.
