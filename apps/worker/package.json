{
  "name": "@olshop/worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "node scripts/with-env.mjs tsx watch src/index.ts",
    "start": "node scripts/with-env.mjs node dist/index.js",
    "enqueue": "pnpm --filter @olshop/queue build && node scripts/with-env.mjs node scripts/enqueue-test.mjs",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@olshop/config": "workspace:*",
    "@olshop/db": "workspace:*",
    "@olshop/queue": "workspace:*",
    "@olshop/utils": "workspace:*",
    "dotenv": "^16.5.0"
  },
  "devDependencies": {
    "@olshop/eslint-config": "workspace:*",
    "@olshop/typescript-config": "workspace:*",
    "@types/node": "^22.14.1",
    "eslint": "^9.24.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
