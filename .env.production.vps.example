# Production env for the single-host VPS deploy (Option A — docker-compose.prod.yml).
# (For the Vercel + Neon path, use .env.production.example instead.)
#   cp .env.production.vps.example .env.production    # then fill in every <...>
#   docker compose -f docker-compose.prod.yml --env-file .env.production up -d --build
# This one file feeds BOTH compose ${var} interpolation and the container runtime env.

# ── Domain / public URLs ───────────────────────────────────────────────────────
# DNS A record for DOMAIN must point to this server (Caddy issues TLS for it).
DOMAIN=app.example.com

# NEXT_PUBLIC_* are inlined at BUILD time — change them ⇒ rebuild (`--build`).
NEXT_PUBLIC_APP_URL=https://app.example.com
NEXT_PUBLIC_APP_NAME=Falka
# Single host = same-origin Socket.IO, so the mobile scanner works here. Enable it:
NEXT_PUBLIC_ENABLE_MOBILE_SCANNER=true
# Leave NEXT_PUBLIC_SOCKET_URL UNSET — same-origin. (Only for the split Vercel+socket setup.)
# AUTH_COOKIE_DOMAIN unset — single host, host-only cookie is fine.

# ── Auth.js ────────────────────────────────────────────────────────────────────
AUTH_SECRET=<openssl rand -base64 32>
AUTH_URL=https://app.example.com

# ── Required secrets ───────────────────────────────────────────────────────────
# REQUIRED (min 32 chars) even with no marketplace connections yet — it encrypts
# stored marketplace tokens and is validated at boot, so web AND worker refuse to
# start without it. Generate once and keep it stable (rotating it orphans tokens).
MARKETPLACE_ENCRYPTION_SECRET=<openssl rand -base64 32>

# ── Postgres (the compose `postgres` service) ──────────────────────────────────
POSTGRES_USER=falka
POSTGRES_PASSWORD=<change-me>
POSTGRES_DB=falka
DATABASE_URL=postgresql://falka:<change-me>@postgres:5432/falka

# ── Redis (the compose `redis` service) ────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Cloudflare R2 (object storage — keep using R2) ─────────────────────────────
R2_ACCOUNT_ID=<...>
R2_ACCESS_KEY_ID=<...>
R2_SECRET_ACCESS_KEY=<...>
R2_RECORDINGS_BUCKET_NAME=<...>
# Recordings bucket public base (its own r2.dev/custom domain; objects served at root)
R2_PUBLIC_URL=https://<recordings-r2-public-domain>
R2_PRODUCTS_BUCKET_NAME=<...>
# Products bucket public base (its own r2.dev/custom domain; objects served at root)
R2_PRODUCTS_PUBLIC_URL=https://<products-r2-public-domain>

# ── Runtime ────────────────────────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info
# WORKER_ENABLE_SCHEDULERS=true
# WORKER_HEALTH_PORT=3001

# ── Marketplace integrations (optional — only if used) ─────────────────────────
# (MARKETPLACE_ENCRYPTION_SECRET is set above — it is required regardless.)
# SHOPEE_PARTNER_ID=<...>
# SHOPEE_PARTNER_KEY=<...>
# TOKOPEDIA_CLIENT_ID=<...>
# TOKOPEDIA_CLIENT_SECRET=<...>

# ── Sentry (optional) ──────────────────────────────────────────────────────────
# SENTRY_DSN=<...>
# NEXT_PUBLIC_SENTRY_DSN=<...>
# SENTRY_ENVIRONMENT=production
