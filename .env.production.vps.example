# Per-ENVIRONMENT config for the single-host VPS deploy (docker-compose.prod.yml).
# Copy ONE per environment, into that environment's own checkout dir:
#   ~/apps/palka-prod/.env.production     (prod values below)
#   ~/apps/palka-staging/.env.production  (staging values: APP_IMAGE=falka-app:staging,
#                                          WEB_ALIAS=palka-staging-web, the staging domain)
# Then: docker compose -p <palka-prod|palka-staging> --env-file .env.production up -d --build
# This one file feeds BOTH compose ${var} interpolation AND the container runtime env.

# ── Per-environment identity ─────────────────────────────────────────────────────
# Distinct image tag per env (NEXT_PUBLIC_* are build-time → each env needs its own build).
APP_IMAGE=falka-app:prod
# The alias the shared Caddy routes to (must match Caddyfile): palka-prod-web / palka-staging-web.
WEB_ALIAS=palka-prod-web

# ── Domain / public URLs ─────────────────────────────────────────────────────────
# NEXT_PUBLIC_* are inlined at BUILD time — change them ⇒ rebuild (`up -d --build`).
NEXT_PUBLIC_APP_URL=https://palka.app
NEXT_PUBLIC_APP_NAME=Falka
# Single host = same-origin Socket.IO, so the mobile scanner works here. Keep it on:
NEXT_PUBLIC_ENABLE_MOBILE_SCANNER=true
# Leave NEXT_PUBLIC_SOCKET_URL UNSET — same-origin. AUTH_COOKIE_DOMAIN unset — host-only cookie is fine.

# ── Auth.js ──────────────────────────────────────────────────────────────────────
AUTH_SECRET=<openssl rand -base64 32>
AUTH_URL=https://palka.app

# ── Required secrets ───────────────────────────────────────────────────────────────
# REQUIRED (min 32 chars) even with no marketplace connections — it encrypts stored
# marketplace tokens and is validated at boot (web AND worker refuse to start without it).
# Generate ONCE and keep it stable + identical across web/worker (rotating orphans tokens).
MARKETPLACE_ENCRYPTION_SECRET=<openssl rand -base64 32>

# ── Postgres (the compose `postgres` service) ──────────────────────────────────────
POSTGRES_USER=falka
POSTGRES_PASSWORD=<change-me>
POSTGRES_DB=falka
DATABASE_URL=postgresql://falka:<change-me>@postgres:5432/falka
# Self-hosted Postgres isn't pooled, so directUrl == DATABASE_URL.
DIRECT_URL=postgresql://falka:<change-me>@postgres:5432/falka

# ── Redis (the compose `redis` service) ────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Worker ─────────────────────────────────────────────────────────────────────────
# On the VPS the worker DOES run (unlike Vercel). Enable schedulers so the daily jobs
# (marketplace reconcile + token refresh) fire.
WORKER_ENABLE_SCHEDULERS=true
# WORKER_HEALTH_PORT=3001

# ── DB backup (the compose `backup` service) ───────────────────────────────────────
BACKUP_INTERVAL_SECONDS=86400
BACKUP_KEEP=7

# ── Cloudflare R2 (object storage — keep using R2) ─────────────────────────────────
R2_ACCOUNT_ID=<...>
R2_ACCESS_KEY_ID=<...>
R2_SECRET_ACCESS_KEY=<...>
R2_RECORDINGS_BUCKET_NAME=<...>
R2_PUBLIC_URL=https://<recordings-r2-public-domain>
R2_PRODUCTS_BUCKET_NAME=<...>
R2_PRODUCTS_PUBLIC_URL=https://<products-r2-public-domain>

# ── Lazada (REAL adapter — fill when connecting a shop) ────────────────────────────
# Region gateway must match the seller's country (ID = api.lazada.co.id/rest).
# LAZADA_APP_KEY=<...>
# LAZADA_APP_SECRET=<...>
# LAZADA_API_BASE_URL=https://api.lazada.co.id/rest
# Must be https on THIS domain AND registered exactly in the Lazada console:
# LAZADA_OAUTH_REDIRECT_URI=https://palka.app/api/v1/marketplaces/lazada/oauth/callback

# ── Runtime ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info

# ── Other marketplaces (stubs — optional) ──────────────────────────────────────────
# SHOPEE_PARTNER_ID=<...>
# SHOPEE_PARTNER_KEY=<...>

# ── Sentry (optional) ──────────────────────────────────────────────────────────────
# SENTRY_DSN=<...>
# NEXT_PUBLIC_SENTRY_DSN=<...>
# SENTRY_ENVIRONMENT=production
