# =============================================================================
# Palka — Local development environment (server + shared)
# Copy to .env at monorepo root: cp .env.example .env
# Sync server vars to apps/web/.env.local for Next.js (see docs/environment.md)
# =============================================================================

# Runtime
NODE_ENV=development
LOG_LEVEL=debug
# Set to 1 to log every Prisma SQL query to stdout in dev (noisy; off by default).
# PRISMA_LOG_QUERY=1

# PostgreSQL (Docker Compose default)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/palka
# Prisma migrations use a DIRECT (non-pooled) connection. Locally = same as DATABASE_URL.
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/palka

# Redis (Docker Compose default — prepared for future BullMQ workers)
REDIS_URL=redis://localhost:6379

# Auth.js (generate: openssl rand -base64 32)
AUTH_SECRET=change-me-to-a-secure-random-string-at-least-32-chars
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
# Prod only: share the session cookie with the separate socket subdomain.
# Leave unset locally (host-only cookie). See docs/deployment/socket-server.md
# AUTH_COOKIE_DOMAIN=.example.com

# Cloudflare R2
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_RECORDINGS_BUCKET_NAME=palka-recordings
# Recordings bucket public base (its own r2.dev/custom domain; objects served at root)
R2_PUBLIC_URL=https://pub-xxxxxxxx.r2.dev
# Separate public bucket for product/variant images (same account)
R2_PRODUCTS_BUCKET_NAME=palka-products
# Products bucket public base (its own r2.dev/custom domain; objects served at root)
R2_PRODUCTS_PUBLIC_URL=https://pub-yyyyyyyy.r2.dev

# Marketplace token encryption (generate: openssl rand -base64 32)
MARKETPLACE_ENCRYPTION_SECRET=change-me-to-a-secure-random-string-at-least-32-chars

# Marketplace adapters are env-gated: unset => Dev/stub fallback. Lazada is live;
# Shopee + Tokopedia are scaffolded (Tokopedia runs on the TikTok Shop Open API).

# Shopee Open Platform v2
SHOPEE_PARTNER_ID=
SHOPEE_PARTNER_KEY=
SHOPEE_API_BASE_URL=
# https://<your-domain>/api/v1/marketplaces/shopee/oauth/callback
SHOPEE_OAUTH_REDIRECT_URI=

# Tokopedia channel via the TikTok Shop Open API (the standalone Tokopedia API is dead)
TOKOPEDIA_APP_KEY=
TOKOPEDIA_APP_SECRET=
TOKOPEDIA_SERVICE_ID=
TOKOPEDIA_API_BASE_URL=
# https://<your-domain>/api/v1/marketplaces/tokopedia/oauth/callback
TOKOPEDIA_OAUTH_REDIRECT_URI=

# Lazada Open Platform (app_key/app_secret from open.lazada.com; sandbox-first)
LAZADA_APP_KEY=
LAZADA_APP_SECRET=
LAZADA_API_BASE_URL=https://api.lazada.co.id/rest
# OAuth callback registered in the Lazada app (must match exactly), e.g.
# https://<your-domain>/api/v1/marketplaces/lazada/oauth/callback
LAZADA_OAUTH_REDIRECT_URI=

# Worker process (BullMQ — runs as its own process)
WORKER_HEALTH_PORT=3001
WORKER_ENABLE_SCHEDULERS=true
WORKER_HEALTH_URL=http://127.0.0.1:3001/health
WORKER_SHUTDOWN_TIMEOUT_MS=30000

# Observability (production only — do not set locally)
# Configure in the Coolify env (web + worker) instead.
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
# NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
LOG_PRETTY=true
APP_VERSION=dev

# Docker Compose overrides (optional)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=palka
POSTGRES_PORT=5432
REDIS_PORT=6379

# Database seed (optional)
SEED_ADMIN_EMAIL=admin@palka.local
SEED_ADMIN_PASSWORD=Admin123!
SEED_DEMO_PASSWORD=Demo123!
