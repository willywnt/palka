# =============================================================================
# Olshop — Local development environment (server + shared)
# Copy to .env at monorepo root: cp .env.example .env
# Sync server vars to apps/web/.env.local for Next.js (see docs/environment.md)
# =============================================================================

# Runtime
NODE_ENV=development
LOG_LEVEL=debug

# PostgreSQL (Docker Compose default)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/olshop

# Redis (Docker Compose default — prepared for future BullMQ workers)
REDIS_URL=redis://localhost:6379

# Auth.js (generate: openssl rand -base64 32)
AUTH_SECRET=change-me-to-a-secure-random-string-at-least-32-chars
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
# Prod only: share the session cookie with the separate socket subdomain.
# Leave unset locally (host-only cookie). See docs/deployment/socket-server.md
# AUTH_COOKIE_DOMAIN=.example.com

# Cloudflare R2
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_RECORDINGS_BUCKET_NAME=olshop-recordings
# Recordings bucket public base (its own r2.dev/custom domain; objects served at root)
R2_PUBLIC_URL=https://pub-xxxxxxxx.r2.dev
# Separate public bucket for product/variant images (same account)
R2_PRODUCTS_BUCKET_NAME=olshop-products
# Products bucket public base (its own r2.dev/custom domain; objects served at root)
R2_PRODUCTS_PUBLIC_URL=https://pub-yyyyyyyy.r2.dev

# Marketplace token encryption (generate: openssl rand -base64 32)
MARKETPLACE_ENCRYPTION_SECRET=change-me-to-a-secure-random-string-at-least-32-chars

# Marketplace OAuth (optional — future integration)
SHOPEE_PARTNER_ID=
SHOPEE_PARTNER_KEY=
TOKOPEDIA_CLIENT_ID=
TOKOPEDIA_CLIENT_SECRET=

# Worker process (BullMQ — run separately from Vercel)
WORKER_HEALTH_PORT=3001
WORKER_ENABLE_SCHEDULERS=true
WORKER_HEALTH_URL=http://127.0.0.1:3001/health
WORKER_SHUTDOWN_TIMEOUT_MS=30000

# Observability (production only — do not set locally)
# Configure in Vercel Production + worker host env instead.
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
# NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
LOG_PRETTY=true
APP_VERSION=dev

# Docker Compose overrides (optional)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=olshop
POSTGRES_PORT=5432
REDIS_PORT=6379

# Database seed (optional)
SEED_ADMIN_EMAIL=admin@olshop.local
SEED_ADMIN_PASSWORD=Admin123!
SEED_DEMO_PASSWORD=Demo123!
