{
  "name": "@falka/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    },
    "./validators": {
      "types": "./dist/validators/index.d.ts",
      "default": "./dist/validators/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "with-env": "node scripts/with-env.mjs",
    "db:up": "node scripts/db-docker.mjs up",
    "db:down": "node scripts/db-docker.mjs down",
    "db:wait": "node scripts/with-env.mjs node scripts/ensure-database.mjs",
    "db:setup": "node scripts/db-setup.mjs",
    "db:generate": "prisma generate",
    "db:push": "node scripts/with-env.mjs prisma db push",
    "db:migrate:dev": "node scripts/with-env.mjs prisma migrate dev",
    "db:migrate:deploy": "node scripts/migrate-deploy.mjs",
    "db:migrate:reset": "node scripts/with-env.mjs prisma migrate reset",
    "db:seed": "node scripts/with-env.mjs prisma db seed",
    "db:bootstrap-admin": "tsx prisma/bootstrap-admin.ts",
    "db:reset-demo": "node scripts/with-env.mjs tsx scripts/reset-demo.ts",
    "db:studio": "node scripts/with-env.mjs prisma studio",
    "postinstall": "prisma generate --schema=./prisma/schema.prisma"
  },
  "prisma": {
    "seed": "node scripts/with-env.mjs tsx prisma/seed.ts"
  },
  "dependencies": {
    "@falka/config": "workspace:*",
    "@prisma/client": "^6.8.2",
    "prisma": "^6.8.2",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@falka/eslint-config": "workspace:*",
    "@falka/typescript-config": "workspace:*",
    "argon2": "^0.44.0",
    "dotenv": "^16.5.0",
    "eslint": "^9.24.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
