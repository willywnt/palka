generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  USER
}

enum RecordingStatus {
  RECORDING
  UPLOADING
  COMPLETED
  FAILED
  PENDING_DELETE
  DELETED
}

enum MarketplaceProvider {
  SHOPEE
  TOKOPEDIA
  TIKTOK
  LAZADA
}

enum MarketplaceAccountStatus {
  CONNECTED
  EXPIRED
  DISCONNECTED
  ERROR
  RECONNECT_REQUIRED
  SYNC_DISABLED
}

enum InventoryEventType {
  INCREASE
  DECREASE
  ADJUSTMENT
  RESERVE
  RELEASE
  SYNC
}

enum MarketplaceSyncStatus {
  PENDING
  SYNCING
  SYNCED
  FAILED
  CONFLICT
}

enum MarketplaceMappingStatus {
  MAPPED
  UNMAPPED
  BROKEN
  CONFLICT
  SYNC_DISABLED
}

enum MarketplaceSyncJobStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
  RETRYING
  DISABLED
}

enum MarketplaceSyncType {
  STOCK_PUSH
  STOCK_RECONCILE
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  passwordHash      String
  displayName       String?
  role              UserRole  @default(USER)
  storageQuotaBytes BigInt    @default(524288000)
  storageUsedBytes  BigInt    @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  recordings             Recording[]
  marketplaceAccounts MarketplaceAccount[]
  auditLogs              AuditLog[]
  products               Product[]
  productVariants        ProductVariant[]
  inventoryEvents        InventoryEvent[]        @relation("InventoryEventOwner")
  inventoryEventsActed   InventoryEvent[]        @relation("InventoryEventActor")

  @@map("users")
}

model Recording {
  id                String          @id @default(cuid())
  userId            String
  user              User            @relation(fields: [userId], references: [id])
  noResi            String
  generatedFilename String
  storageProvider   String
  storageBucket     String
  storageKey        String          @unique
  publicUrl         String
  mimeType          String
  fileSizeBytes     BigInt
  durationSeconds   Int
  status            RecordingStatus
  failureCode       String?
  failureReason     String?
  startedAt         DateTime
  stoppedAt         DateTime?
  uploadedAt        DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  deletedAt         DateTime?

  @@index([userId])
  @@index([noResi])
  @@index([status])
  @@map("recordings")
}

model MarketplaceAccount {
  id                    String                   @id @default(cuid())
  userId                String
  user                  User                     @relation(fields: [userId], references: [id])
  provider              MarketplaceProvider
  storeName             String
  externalStoreId       String
  encryptedAccessToken  String
  encryptedRefreshToken String?
  tokenExpiresAt        DateTime?
  status                MarketplaceAccountStatus @default(CONNECTED)
  lastConnectedAt       DateTime?
  lastSyncAt            DateTime?
  metadata              Json?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  deletedAt             DateTime?

  products        MarketplaceProduct[]
  productMappings MarketplaceProductMapping[]
  syncJobs        MarketplaceSyncJob[]
  providerHealth  MarketplaceProviderHealth?

  @@unique([userId, provider, externalStoreId])
  @@index([userId])
  @@index([provider])
  @@index([status])
  @@index([tokenExpiresAt])
  @@map("marketplace_accounts")
}

model Product {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  name        String
  slug        String
  brand       String?
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  variants ProductVariant[]

  @@unique([userId, slug])
  @@index([userId])
  @@index([slug])
  @@index([isActive])
  @@map("products")
}

model ProductVariant {
  id         String    @id @default(cuid())
  productId  String
  product    Product   @relation(fields: [productId], references: [id])
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  sku        String
  barcode    String?
  name       String
  price      Decimal   @db.Decimal(12, 2)
  cost       Decimal?  @db.Decimal(12, 2)
  weight     Decimal?  @db.Decimal(10, 3)
  dimensions Json?
  isActive   Boolean   @default(true)
  lowStockThreshold Int      @default(5)
  alertEnabled      Boolean  @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  inventory           Inventory?
  inventoryEvents     InventoryEvent[]
  marketplaceMappings MarketplaceProductMapping[]

  @@unique([userId, sku])
  @@index([productId])
  @@index([userId])
  @@index([sku])
  @@index([barcode])
  @@index([isActive])
  @@map("product_variants")
}

model Inventory {
  id             String         @id @default(cuid())
  variantId      String         @unique
  variant        ProductVariant @relation(fields: [variantId], references: [id])
  availableStock Int            @default(0)
  reservedStock  Int            @default(0)
  damagedStock   Int            @default(0)
  incomingStock  Int            @default(0)
  lastAdjustedAt DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([variantId])
  @@index([availableStock])
  @@map("inventory")
}

model InventoryEvent {
  id            String             @id @default(cuid())
  variantId     String
  variant       ProductVariant     @relation(fields: [variantId], references: [id])
  userId        String
  user          User               @relation("InventoryEventOwner", fields: [userId], references: [id])
  type          InventoryEventType
  quantity      Int
  previousStock Int
  newStock      Int
  reason        String?
  metadata      Json?
  actorId       String?
  actor         User?              @relation("InventoryEventActor", fields: [actorId], references: [id])
  createdAt     DateTime           @default(now())

  @@index([variantId])
  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@index([actorId])
  @@map("inventory_events")
}

/// Cached marketplace product snapshot — NOT internal inventory.
model MarketplaceProduct {
  id                   String              @id @default(cuid())
  marketplaceAccountId String
  marketplaceAccount   MarketplaceAccount  @relation(fields: [marketplaceAccountId], references: [id])
  provider             MarketplaceProvider
  externalProductId    String
  externalVariantId    String
  externalSku          String?
  externalProductName  String
  externalVariantName  String?
  stock                Int                 @default(0)
  status               String              @default("active")
  rawPayload           Json?
  lastImportedAt       DateTime            @default(now())
  lastSyncedAt         DateTime?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  deletedAt            DateTime?

  mappings MarketplaceProductMapping[]

  @@unique([marketplaceAccountId, externalVariantId])
  @@index([marketplaceAccountId])
  @@index([provider])
  @@index([externalSku])
  @@index([status])
  @@index([lastImportedAt])
  @@map("marketplace_products")
}

/// Maps internal ProductVariant ↔ cached MarketplaceProduct.
model MarketplaceProductMapping {
  id                   String                   @id @default(cuid())
  productVariantId     String
  productVariant       ProductVariant           @relation(fields: [productVariantId], references: [id])
  marketplaceProductId String
  marketplaceProduct   MarketplaceProduct       @relation(fields: [marketplaceProductId], references: [id])
  marketplaceAccountId String
  marketplaceAccount   MarketplaceAccount       @relation(fields: [marketplaceAccountId], references: [id])
  provider             MarketplaceProvider
  mappingStatus        MarketplaceMappingStatus @default(MAPPED)
  syncEnabled          Boolean                  @default(true)
  autoMapped           Boolean                  @default(false)
  mappingConfidence    Decimal?                 @db.Decimal(5, 4)
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt
  deletedAt            DateTime?

  syncLogs MarketplaceSyncLog[]
  syncJobs MarketplaceSyncJob[]

  @@unique([marketplaceAccountId, productVariantId])
  @@unique([marketplaceAccountId, marketplaceProductId])
  @@index([productVariantId])
  @@index([marketplaceProductId])
  @@index([mappingStatus])
  @@index([syncEnabled])
  @@map("marketplace_product_mappings")
}

/// Future sync audit trail for marketplace reconciliation jobs.
model MarketplaceSyncLog {
  id        String                    @id @default(cuid())
  mappingId String
  mapping   MarketplaceProductMapping @relation(fields: [mappingId], references: [id])
  status    MarketplaceSyncStatus
  direction String
  message   String?
  metadata  Json?
  createdAt DateTime                  @default(now())

  @@index([mappingId])
  @@index([status])
  @@index([createdAt])
  @@map("marketplace_sync_logs")
}

/// Async stock sync job — persisted queue state for operational visibility.
model MarketplaceSyncJob {
  id                          String                   @id @default(cuid())
  marketplaceAccountId        String
  marketplaceAccount          MarketplaceAccount       @relation(fields: [marketplaceAccountId], references: [id])
  marketplaceProductMappingId String
  mapping                     MarketplaceProductMapping @relation(fields: [marketplaceProductMappingId], references: [id])
  provider                    MarketplaceProvider
  syncType                    MarketplaceSyncType      @default(STOCK_PUSH)
  syncStatus                  MarketplaceSyncJobStatus @default(PENDING)
  payload                     Json?
  providerResponse            Json?
  idempotencyKey              String?                  @unique
  attempts                    Int                      @default(0)
  errorMessage                String?
  lastAttemptAt               DateTime?
  completedAt                 DateTime?
  createdAt                   DateTime                 @default(now())
  updatedAt                   DateTime                 @updatedAt

  @@index([marketplaceAccountId])
  @@index([marketplaceProductMappingId])
  @@index([syncStatus])
  @@index([syncType])
  @@index([createdAt])
  @@index([lastAttemptAt])
  @@map("marketplace_sync_jobs")
}

/// Provider API health snapshot for operational monitoring.
model MarketplaceProviderHealth {
  id                   String             @id @default(cuid())
  marketplaceAccountId String             @unique
  marketplaceAccount   MarketplaceAccount @relation(fields: [marketplaceAccountId], references: [id])
  lastSuccessAt        DateTime?
  lastFailureAt        DateTime?
  consecutiveFailures  Int                @default(0)
  averageLatencyMs     Int?
  lastErrorCode        String?
  tokenValid           Boolean            @default(true)
  updatedAt            DateTime           @updatedAt

  @@map("marketplace_provider_health")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  resource  String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@map("audit_logs")
}
