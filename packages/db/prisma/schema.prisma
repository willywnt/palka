generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  USER
}

enum RecordingStatus {
  RECORDING
  UPLOADING
  COMPLETED
  FAILED
  PENDING_DELETE
  DELETED
}

enum MarketplaceProvider {
  SHOPEE
  TOKOPEDIA
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  passwordHash      String
  displayName       String?
  role              UserRole  @default(USER)
  storageQuotaBytes BigInt    @default(524288000)
  storageUsedBytes  BigInt    @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  recordings                 Recording[]
  pairingSessions            PairingSession[]
  marketplaceConnections     MarketplaceConnection[]
  auditLogs                  AuditLog[]
  products                   Product[]
  productVariants            ProductVariant[]
  stockLedgerEntries         StockLedger[]
  marketplaceProducts        MarketplaceProduct[]
  marketplaceProductMappings MarketplaceProductMapping[]
  marketplaceSyncJobs        MarketplaceSyncJob[]
  orders                     Order[]

  @@map("users")
}

enum PairingSessionStatus {
  PENDING
  CONNECTED
  DISCONNECTED
  EXPIRED
}

model PairingSession {
  id          String               @id @default(uuid())
  userId      String
  user        User                 @relation(fields: [userId], references: [id])
  pairingCode String
  status      PairingSessionStatus @default(PENDING)
  connectedAt DateTime?
  lastSeenAt  DateTime?
  expiresAt   DateTime
  deviceInfo  Json?
  lastScanAt  DateTime?
  lastBarcode String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([userId])
  @@index([status])
  @@index([expiresAt])
  @@map("pairing_sessions")
}

model Recording {
  id                String          @id @default(cuid())
  userId            String
  user              User            @relation(fields: [userId], references: [id])
  noResi            String
  generatedFilename String
  storageProvider   String
  storageBucket     String
  storageKey        String          @unique
  publicUrl         String
  mimeType          String
  fileSizeBytes     BigInt
  durationSeconds   Int
  status            RecordingStatus
  failureCode       String?
  failureReason     String?
  startedAt         DateTime
  stoppedAt         DateTime?
  uploadedAt        DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  deletedAt         DateTime?

  @@index([userId])
  @@index([noResi])
  @@index([status])
  @@map("recordings")
}

model MarketplaceConnection {
  id                    String              @id @default(cuid())
  userId                String
  user                  User                @relation(fields: [userId], references: [id])
  provider              MarketplaceProvider
  shopId                String
  shopName              String
  encryptedAccessToken  String
  encryptedRefreshToken String?
  tokenExpiresAt        DateTime?
  isActive              Boolean             @default(true)
  lastImportedAt        DateTime?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  deletedAt             DateTime?

  marketplaceProducts MarketplaceProduct[]
  productMappings     MarketplaceProductMapping[]
  syncJobs            MarketplaceSyncJob[]
  orders              Order[]

  @@index([userId])
  @@index([provider])
  @@map("marketplace_connections")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  resource  String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@map("audit_logs")
}

enum StockLedgerReason {
  MANUAL_ADJUST
  RESTOCK
  DAMAGE
  ORDER_RESERVE
  ORDER_RELEASE
  ORDER_SHIP
  MARKETPLACE_SYNC
  RECONCILE
}

enum StockLedgerSource {
  MANUAL
  MARKETPLACE
  SYSTEM
}

model Product {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  name        String
  description String?
  category    String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  variants ProductVariant[]

  @@index([userId])
  @@map("products")
}

model ProductVariant {
  id                String    @id @default(cuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id])
  productId         String
  product           Product   @relation(fields: [productId], references: [id])
  sku               String
  name              String
  barcode           String?
  price             Decimal   @db.Decimal(12, 2)
  cost              Decimal?  @db.Decimal(12, 2)
  weight            Decimal?  @db.Decimal(10, 3) // kilograms
  dimensions        Json?
  isActive          Boolean   @default(true)
  lowStockThreshold Int       @default(0)
  alertEnabled      Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  inventory           Inventory?
  ledgerEntries       StockLedger[]
  marketplaceMappings MarketplaceProductMapping[]
  orderItems          OrderItem[]

  @@unique([userId, sku])
  @@index([userId])
  @@index([productId])
  @@index([barcode])
  @@map("product_variants")
}

model Inventory {
  id             String         @id @default(cuid())
  variantId      String         @unique
  variant        ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  availableStock Int            @default(0)
  reservedStock  Int            @default(0)
  damagedStock   Int            @default(0)
  incomingStock  Int            @default(0)
  lastAdjustedAt DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@map("inventories")
}

model StockLedger {
  id           String            @id @default(cuid())
  userId       String
  user         User              @relation(fields: [userId], references: [id])
  variantId    String
  variant      ProductVariant    @relation(fields: [variantId], references: [id])
  delta        Int
  balanceAfter Int
  reason       StockLedgerReason
  source       StockLedgerSource
  referenceId  String?
  note         String?
  createdAt    DateTime          @default(now())

  @@index([userId])
  @@index([variantId])
  @@index([createdAt])
  @@map("stock_ledger_entries")
}

enum MarketplaceMappingStatus {
  MAPPED
  NEEDS_REVIEW
}

model MarketplaceProduct {
  id                      String                @id @default(cuid())
  userId                  String
  user                    User                  @relation(fields: [userId], references: [id])
  marketplaceConnectionId String
  connection              MarketplaceConnection @relation(fields: [marketplaceConnectionId], references: [id], onDelete: Cascade)
  provider                MarketplaceProvider
  externalProductId       String
  externalVariantId       String
  externalSku             String?
  externalProductName     String
  externalVariantName     String?
  stock                   Int                   @default(0)
  status                  String
  rawPayload              Json?
  lastImportedAt          DateTime
  lastSyncedAt            DateTime?
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  deletedAt               DateTime?

  mapping MarketplaceProductMapping?

  @@unique([marketplaceConnectionId, externalProductId, externalVariantId])
  @@index([userId])
  @@index([marketplaceConnectionId])
  @@index([externalSku])
  @@map("marketplace_products")
}

model MarketplaceProductMapping {
  id                      String                   @id @default(cuid())
  userId                  String
  user                    User                     @relation(fields: [userId], references: [id])
  marketplaceConnectionId String
  connection              MarketplaceConnection    @relation(fields: [marketplaceConnectionId], references: [id], onDelete: Cascade)
  marketplaceProductId    String                   @unique
  marketplaceProduct      MarketplaceProduct       @relation(fields: [marketplaceProductId], references: [id], onDelete: Cascade)
  productVariantId        String
  productVariant          ProductVariant           @relation(fields: [productVariantId], references: [id])
  provider                MarketplaceProvider
  mappingStatus           MarketplaceMappingStatus @default(MAPPED)
  syncEnabled             Boolean                  @default(false)
  autoMapped              Boolean                  @default(false)
  mappingConfidence       Decimal?                 @db.Decimal(3, 2)
  lastSyncedAt            DateTime?
  lastSyncStatus          MarketplaceSyncStatus?
  lastSyncError           String?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt

  syncJobs MarketplaceSyncJob[]

  @@index([userId])
  @@index([marketplaceConnectionId])
  @@index([productVariantId])
  @@map("marketplace_product_mappings")
}

enum MarketplaceSyncStatus {
  PENDING
  SYNCED
  FAILED
}

enum MarketplaceSyncJobStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
  DISABLED
  SKIPPED
}

model MarketplaceSyncJob {
  id                          String                    @id @default(cuid())
  userId                      String
  user                        User                      @relation(fields: [userId], references: [id])
  marketplaceConnectionId     String
  connection                  MarketplaceConnection     @relation(fields: [marketplaceConnectionId], references: [id], onDelete: Cascade)
  marketplaceProductMappingId String
  mapping                     MarketplaceProductMapping @relation(fields: [marketplaceProductMappingId], references: [id], onDelete: Cascade)
  provider                    MarketplaceProvider
  idempotencyKey              String                    @unique
  syncStatus                  MarketplaceSyncJobStatus  @default(PENDING)
  payload                     Json
  providerResponse            Json?
  attempts                    Int                       @default(0)
  errorMessage                String?
  lastAttemptAt               DateTime?
  completedAt                 DateTime?
  createdAt                   DateTime                  @default(now())
  updatedAt                   DateTime                  @updatedAt

  @@index([userId])
  @@index([marketplaceProductMappingId])
  @@index([syncStatus])
  @@map("marketplace_sync_jobs")
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  COMPLETED
  CANCELLED
}

model Order {
  id                      String                @id @default(cuid())
  userId                  String
  user                    User                  @relation(fields: [userId], references: [id])
  marketplaceConnectionId String
  connection              MarketplaceConnection @relation(fields: [marketplaceConnectionId], references: [id], onDelete: Cascade)
  provider                MarketplaceProvider
  externalOrderId         String
  status                  OrderStatus
  noResi                  String?
  buyerName               String?
  totalAmount             Decimal?              @db.Decimal(14, 2)
  currency                String?
  rawPayload              Json?
  placedAt                DateTime
  /**
   * Set once a PAID order's items have decremented internal stock (idempotency).
   */
  inventoryAppliedAt      DateTime?
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt

  items OrderItem[]

  @@unique([marketplaceConnectionId, externalOrderId])
  @@index([userId])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id                String          @id @default(cuid())
  orderId           String
  order             Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  externalProductId String
  externalVariantId String
  externalSku       String?
  externalName      String
  quantity          Int
  unitPrice         Decimal?        @db.Decimal(12, 2)
  /**
   * Resolved internal variant (via marketplace mapping); null when unresolved.
   */
  productVariantId  String?
  productVariant    ProductVariant? @relation(fields: [productVariantId], references: [id])
  createdAt         DateTime        @default(now())

  @@index([orderId])
  @@index([productVariantId])
  @@map("order_items")
}
