generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  USER
}

/**
 * Role within an organization (workspace). Separate from UserRole = platform admin.
 */
enum OrgRole {
  OWNER
  ADMIN
  STAFF
}

enum RecordingStatus {
  RECORDING
  UPLOADING
  COMPLETED
  FAILED
  PENDING_DELETE
  DELETED
}

enum MarketplaceProvider {
  SHOPEE
  TOKOPEDIA
  LAZADA
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  displayName  String?
  role         UserRole  @default(USER)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  recordings                 Recording[]
  pairingSessions            PairingSession[]
  marketplaceConnections     MarketplaceConnection[]
  auditLogs                  AuditLog[]
  products                   Product[]
  productVariants            ProductVariant[]
  stockLedgerEntries         StockLedger[]
  marketplaceProducts        MarketplaceProduct[]
  marketplaceProductMappings MarketplaceProductMapping[]
  marketplaceSyncJobs        MarketplaceSyncJob[]
  orders                     Order[]
  returns                    Return[]
  sales                      Sale[]
  saleRefunds                SaleRefund[]
  purchaseOrders             PurchaseOrder[]
  recordingShareLinks        RecordingShareLink[]
  bundles                    Bundle[]
  stockOpnames               StockOpname[]
  membership                 OrganizationMember?
  createdInvites             OrganizationInvite[]        @relation("InviteCreatedBy")
  usedInvites                OrganizationInvite[]        @relation("InviteUsedBy")

  @@map("users")
}

/**
 * The workspace every piece of shop data belongs to. For accounts that existed
 * before organizations, id := the owner User.id (the backfill trick) — that
 * keeps R2 storage-key prefixes and per-scope code sequences valid verbatim.
 * New registrations get a fresh cuid.
 */
model Organization {
  id                String    @id @default(cuid())
  name              String
  /**
   * Storage quota lives on the org (moved off User; the whole shop shares it).
   */
  storageQuotaBytes BigInt    @default(524288000)
  storageUsedBytes  BigInt    @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  members OrganizationMember[]
  invites OrganizationInvite[]

  pairingSessions            PairingSession[]
  recordings                 Recording[]
  recordingShareLinks        RecordingShareLink[]
  marketplaceConnections     MarketplaceConnection[]
  auditLogs                  AuditLog[]
  products                   Product[]
  productVariants            ProductVariant[]
  bundles                    Bundle[]
  stockLedgerEntries         StockLedger[]
  marketplaceProducts        MarketplaceProduct[]
  marketplaceProductMappings MarketplaceProductMapping[]
  marketplaceSyncJobs        MarketplaceSyncJob[]
  orders                     Order[]
  returns                    Return[]
  sales                      Sale[]
  saleRefunds                SaleRefund[]
  purchaseOrders             PurchaseOrder[]
  stockOpnames               StockOpname[]

  @@map("organizations")
}

model OrganizationMember {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  /**
   * v1: ONE membership per user (drop this unique to allow multi-org later).
   */
  userId         String       @unique
  user           User         @relation(fields: [userId], references: [id])
  role           OrgRole      @default(STAFF)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@map("organization_members")
}

/**
 * A single-use, role-tagged join code (shared via WA — no email infra).
 */
model OrganizationInvite {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  /**
   * 8 chars from A-Z2-9 (no 0/O/1/I) — typed by hand at registration.
   */
  code            String       @unique
  role            OrgRole
  expiresAt       DateTime
  createdByUserId String
  createdBy       User         @relation("InviteCreatedBy", fields: [createdByUserId], references: [id])
  usedByUserId    String?
  usedBy          User?        @relation("InviteUsedBy", fields: [usedByUserId], references: [id])
  usedAt          DateTime?
  revokedAt       DateTime?
  createdAt       DateTime     @default(now())

  @@index([organizationId])
  @@map("organization_invites")
}

enum PairingSessionStatus {
  PENDING
  CONNECTED
  DISCONNECTED
  EXPIRED
}

/**
 * What a paired phone drives: packing-video recordings, POS, or purchase-order restock.
 */
enum PairingPurpose {
  RECORDING
  POS
  PURCHASING
  OPNAME
}

model PairingSession {
  id             String               @id @default(uuid())
  userId         String
  user           User                 @relation(fields: [userId], references: [id])
  // Pairing is a device/auth artifact: queries stay per-user (deliberate exception).
  organizationId String?
  organization   Organization?        @relation(fields: [organizationId], references: [id])
  pairingCode    String
  status         PairingSessionStatus @default(PENDING)
  purpose        PairingPurpose       @default(RECORDING)
  connectedAt    DateTime?
  lastSeenAt     DateTime?
  expiresAt      DateTime
  deviceInfo     Json?
  lastScanAt     DateTime?
  lastBarcode    String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([userId])
  @@index([status])
  @@index([expiresAt])
  @@map("pairing_sessions")
}

model Recording {
  id                String          @id @default(cuid())
  /**
   * Actor: who recorded. Scope queries use organizationId.
   */
  userId            String
  user              User            @relation(fields: [userId], references: [id])
  organizationId    String
  organization      Organization    @relation(fields: [organizationId], references: [id])
  noResi            String
  generatedFilename String
  storageProvider   String
  storageBucket     String
  storageKey        String          @unique
  publicUrl         String
  mimeType          String
  fileSizeBytes     BigInt
  durationSeconds   Int
  status            RecordingStatus
  failureCode       String?
  failureReason     String?
  startedAt         DateTime
  stoppedAt         DateTime?
  uploadedAt        DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  deletedAt         DateTime?

  shareLinks RecordingShareLink[]

  @@index([organizationId])
  @@index([organizationId, noResi])
  @@index([status])
  @@map("recordings")
}

model RecordingShareLink {
  id             String        @id @default(cuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id])
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  recordingId    String
  recording      Recording     @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  // Opaque share token, stored hashed (sha256) — the raw token lives only in the URL.
  tokenHash      String        @unique
  expiresAt      DateTime
  revokedAt      DateTime?
  viewCount      Int           @default(0)
  lastViewedAt   DateTime?
  createdAt      DateTime      @default(now())

  @@index([recordingId])
  @@index([organizationId])
  @@map("recording_share_links")
}

model MarketplaceConnection {
  id                    String              @id @default(cuid())
  userId                String
  user                  User                @relation(fields: [userId], references: [id])
  organizationId        String
  organization          Organization        @relation(fields: [organizationId], references: [id])
  provider              MarketplaceProvider
  shopId                String
  shopName              String
  encryptedAccessToken  String
  encryptedRefreshToken String?
  tokenExpiresAt        DateTime?
  isActive              Boolean             @default(true)
  lastImportedAt        DateTime?
  lastOrdersPulledAt    DateTime? // last time orders were pulled from this store (display + pull cooldown)
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  deletedAt             DateTime?

  marketplaceProducts MarketplaceProduct[]
  productMappings     MarketplaceProductMapping[]
  syncJobs            MarketplaceSyncJob[]
  orders              Order[]

  @@index([organizationId])
  @@index([provider])
  @@map("marketplace_connections")
}

model AuditLog {
  id             String        @id @default(cuid())
  /**
   * Actor (null = system/platform event).
   */
  userId         String?
  user           User?         @relation(fields: [userId], references: [id])
  /**
   * Nullable: platform-level events have no org.
   */
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  action         String
  /**
   * Resource TYPE (e.g. 'sale', 'product'); the row id goes in resourceId.
   */
  resource       String
  resourceId     String?
  ipAddress      String?
  metadata       Json?
  createdAt      DateTime      @default(now())

  @@index([userId])
  @@index([action])
  @@index([organizationId, createdAt])
  @@map("audit_logs")
}

enum StockLedgerReason {
  MANUAL_ADJUST
  RESTOCK
  DAMAGE
  DAMAGE_WRITE_OFF
  ORDER_RESERVE
  ORDER_RELEASE
  ORDER_SHIP
  RETURN
  SALE
  MARKETPLACE_SYNC
  RECONCILE
}

enum StockLedgerSource {
  MANUAL
  MARKETPLACE
  POS
  PURCHASE
  SYSTEM
}

model Product {
  id             String        @id @default(cuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id])
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  name           String
  description    String?
  category       String?
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?

  variants ProductVariant[]

  @@index([organizationId])
  @@map("products")
}

model ProductVariant {
  id                String        @id @default(cuid())
  userId            String
  user              User          @relation(fields: [userId], references: [id])
  organizationId    String
  organization      Organization  @relation(fields: [organizationId], references: [id])
  productId         String
  product           Product       @relation(fields: [productId], references: [id])
  sku               String
  name              String
  barcode           String?
  price             Decimal       @db.Decimal(12, 2)
  cost              Decimal?      @db.Decimal(12, 2)
  weight            Decimal?      @db.Decimal(10, 3) // kilograms
  dimensions        Json?
  // Parent variant name (e.g. "iPhone 16") when this row is a subvariant under a
  // grouped variant; null when the variant stands alone. The variant stays the SKU.
  variantGroup      String?
  // Per-variant photo: R2 object key + its public URL. null = none.
  imageKey          String?
  imageUrl          String?
  isActive          Boolean       @default(true)
  lowStockThreshold Int           @default(0)
  alertEnabled      Boolean       @default(true)
  leadTimeDays      Int? // supplier lead time (days) for reorder planning; null = use global default
  minOrderQty       Int? // minimum reorder quantity (MOQ); null = no minimum
  labelPrintedAt    DateTime? // when a QR/barcode label was last printed for this variant; null = never
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  deletedAt         DateTime?

  inventory           Inventory?
  ledgerEntries       StockLedger[]
  marketplaceMappings MarketplaceProductMapping[]
  orderItems          OrderItem[]
  saleItems           SaleItem[]
  saleRefundItems     SaleRefundItem[]
  purchaseOrderItems  PurchaseOrderItem[]
  bundleItems         BundleItem[]
  stockOpnameItems    StockOpnameItem[]

  @@unique([organizationId, sku])
  @@index([organizationId])
  @@index([productId])
  @@index([barcode])
  @@map("product_variants")
}

/**
 * A bundle/kit: a shortcut that groups several variants for buy/sell. It is NOT a
 * stock variant — it owns no Inventory and never shows in product/inventory lists.
 * Selling/buying a bundle explodes into its component variants; its single price
 * (sell) / cost (entered per-PO) is allocated across components. `barcode ?? sku`
 * is the scannable label code.
 */
model Bundle {
  id             String        @id @default(cuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id])
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  sku            String
  barcode        String?
  name           String
  price          Decimal       @db.Decimal(12, 2)
  isActive       Boolean       @default(true) // inactive bundles can't be sold/bought (hidden from POS/PO pickers + scan)
  imageKey       String?
  imageUrl       String?
  labelPrintedAt DateTime? // when a QR/barcode label was last printed; null = never
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  // Soft-delete (archive). The @@unique([organizationId, sku]) spans archived rows, so the
  // SKU is mangled on archive (see archivedSku) to free the original for reuse.
  deletedAt      DateTime?

  items BundleItem[]

  @@unique([organizationId, sku])
  @@index([organizationId])
  @@index([barcode])
  @@map("bundles")
}

/**
 * One component line of a bundle: `quantity` units of `productVariant` per bundle.
 */
model BundleItem {
  id               String         @id @default(cuid())
  bundleId         String
  bundle           Bundle         @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  productVariantId String
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id])
  quantity         Int

  @@unique([bundleId, productVariantId])
  @@index([bundleId])
  @@index([productVariantId])
  @@map("bundle_items")
}

model Inventory {
  id             String         @id @default(cuid())
  variantId      String         @unique
  variant        ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  availableStock Int            @default(0)
  reservedStock  Int            @default(0)
  damagedStock   Int            @default(0)
  incomingStock  Int            @default(0)
  lastAdjustedAt DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@map("inventories")
}

model StockLedger {
  id             String            @id @default(cuid())
  /**
   * Actor: who triggered the movement. Scope queries use organizationId.
   */
  userId         String
  user           User              @relation(fields: [userId], references: [id])
  organizationId String
  organization   Organization      @relation(fields: [organizationId], references: [id])
  variantId      String
  variant        ProductVariant    @relation(fields: [variantId], references: [id])
  delta          Int
  balanceAfter   Int
  reason         StockLedgerReason
  source         StockLedgerSource
  referenceId    String?
  note           String?
  createdAt      DateTime          @default(now())

  // Serves the reorder report's per-bucket demand sums (userId + reason IN + createdAt range).
  @@index([organizationId, reason, createdAt])
  // Serves the stock-activity log: userId-scoped, newest-first, no reason filter. The
  // reason-prefixed index above can't satisfy this ordering (Postgres has no skip scan).
  @@index([organizationId, createdAt])
  @@index([variantId])
  @@index([createdAt])
  @@map("stock_ledger_entries")
}

enum MarketplaceMappingStatus {
  MAPPED
  NEEDS_REVIEW
}

model MarketplaceProduct {
  id                      String                @id @default(cuid())
  userId                  String
  user                    User                  @relation(fields: [userId], references: [id])
  organizationId          String
  organization            Organization          @relation(fields: [organizationId], references: [id])
  marketplaceConnectionId String
  connection              MarketplaceConnection @relation(fields: [marketplaceConnectionId], references: [id], onDelete: Cascade)
  provider                MarketplaceProvider
  externalProductId       String
  externalVariantId       String
  externalSku             String?
  externalProductName     String
  externalVariantName     String?
  stock                   Int                   @default(0)
  status                  String
  rawPayload              Json?
  lastImportedAt          DateTime
  lastSyncedAt            DateTime?
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  deletedAt               DateTime?

  mapping MarketplaceProductMapping?

  @@unique([marketplaceConnectionId, externalProductId, externalVariantId])
  @@index([organizationId])
  @@index([marketplaceConnectionId])
  @@index([externalSku])
  @@map("marketplace_products")
}

model MarketplaceProductMapping {
  id                      String                   @id @default(cuid())
  userId                  String
  user                    User                     @relation(fields: [userId], references: [id])
  organizationId          String
  organization            Organization             @relation(fields: [organizationId], references: [id])
  marketplaceConnectionId String
  connection              MarketplaceConnection    @relation(fields: [marketplaceConnectionId], references: [id], onDelete: Cascade)
  marketplaceProductId    String                   @unique
  marketplaceProduct      MarketplaceProduct       @relation(fields: [marketplaceProductId], references: [id], onDelete: Cascade)
  productVariantId        String
  productVariant          ProductVariant           @relation(fields: [productVariantId], references: [id])
  provider                MarketplaceProvider
  mappingStatus           MarketplaceMappingStatus @default(MAPPED)
  syncEnabled             Boolean                  @default(false)
  autoMapped              Boolean                  @default(false)
  mappingConfidence       Decimal?                 @db.Decimal(3, 2)
  lastSyncedAt            DateTime?
  lastSyncStatus          MarketplaceSyncStatus?
  lastSyncError           String?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt

  syncJobs MarketplaceSyncJob[]

  @@index([organizationId])
  @@index([marketplaceConnectionId])
  @@index([productVariantId])
  @@map("marketplace_product_mappings")
}

enum MarketplaceSyncStatus {
  PENDING
  SYNCED
  FAILED
}

enum MarketplaceSyncJobStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
  DISABLED
  SKIPPED
}

model MarketplaceSyncJob {
  id                          String                    @id @default(cuid())
  /**
   * Actor: who triggered the change that enqueued this job.
   */
  userId                      String
  user                        User                      @relation(fields: [userId], references: [id])
  organizationId              String
  organization                Organization              @relation(fields: [organizationId], references: [id])
  marketplaceConnectionId     String
  connection                  MarketplaceConnection     @relation(fields: [marketplaceConnectionId], references: [id], onDelete: Cascade)
  marketplaceProductMappingId String
  mapping                     MarketplaceProductMapping @relation(fields: [marketplaceProductMappingId], references: [id], onDelete: Cascade)
  provider                    MarketplaceProvider
  idempotencyKey              String                    @unique
  syncStatus                  MarketplaceSyncJobStatus  @default(PENDING)
  payload                     Json
  providerResponse            Json?
  attempts                    Int                       @default(0)
  errorMessage                String?
  lastAttemptAt               DateTime?
  completedAt                 DateTime?
  createdAt                   DateTime                  @default(now())
  updatedAt                   DateTime                  @updatedAt

  @@index([organizationId])
  @@index([marketplaceProductMappingId])
  @@index([syncStatus])
  @@map("marketplace_sync_jobs")
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  COMPLETED
  CANCELLED
}

model Order {
  id                      String                @id @default(cuid())
  userId                  String
  user                    User                  @relation(fields: [userId], references: [id])
  organizationId          String
  organization            Organization          @relation(fields: [organizationId], references: [id])
  marketplaceConnectionId String
  connection              MarketplaceConnection @relation(fields: [marketplaceConnectionId], references: [id], onDelete: Cascade)
  provider                MarketplaceProvider
  externalOrderId         String
  status                  OrderStatus
  noResi                  String?
  buyerName               String?
  totalAmount             Decimal?              @db.Decimal(14, 2)
  currency                String?
  rawPayload              Json?
  placedAt                DateTime
  /**
   * Set once a PAID order's items have decremented internal stock (idempotency).
   */
  inventoryAppliedAt      DateTime?
  /**
   * Set once a CANCELLED order's previously-applied decrement has been reversed
   * (restocked) back to internal stock (idempotency; mirrors inventoryAppliedAt).
   */
  inventoryRevertedAt     DateTime?
  /**
   * Set once a SHIPPED/COMPLETED order's reservation has been consumed — the
   * reserved units physically left (idempotency; mirrors inventoryAppliedAt).
   */
  inventoryShippedAt      DateTime?
  /**
   * Set when a packing video (a Recording with the same noResi) completes — the
   * order has been packed + recorded. Matched by noResi (no FK).
   */
  fulfilledAt             DateTime?
  /**
   * Free-text reason captured when an order is cancelled manually (null otherwise).
   */
  cancelReason            String?
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt

  items   OrderItem[]
  returns Return[]

  @@unique([marketplaceConnectionId, externalOrderId])
  @@index([organizationId])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id                String          @id @default(cuid())
  orderId           String
  order             Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  externalProductId String
  externalVariantId String
  externalSku       String?
  externalName      String
  quantity          Int
  unitPrice         Decimal?        @db.Decimal(12, 2)
  /**
   * COGS snapshot: the variant's cost at reserve time. null = unknown (pre-backfill).
   */
  unitCost          Decimal?        @db.Decimal(12, 2)
  /**
   * Resolved internal variant (via marketplace mapping); null when unresolved.
   */
  productVariantId  String?
  productVariant    ProductVariant? @relation(fields: [productVariantId], references: [id])
  createdAt         DateTime        @default(now())

  @@index([orderId])
  @@index([productVariantId])
  @@map("order_items")
}

enum ReturnStatus {
  PENDING // opened — awaiting the physical goods
  RECEIVED // goods received and each item dispositioned (stock applied)
  REJECTED // closed without restock (goods not returned / dispute lost)
}

enum ReturnDisposition {
  RESTOCK // resellable — back to available
  DAMAGED // unsellable — into damaged stock
}

model Return {
  id             String        @id @default(cuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id])
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  orderId        String
  order          Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status         ReturnStatus  @default(PENDING)
  reason         String?
  /**
   * True when opened automatically from a detected post-ship cancellation.
   */
  autoDetected   Boolean       @default(false)
  /**
   * Copied from the order for packing-video evidence lookup (matched by noResi).
   */
  noResi         String?
  processedAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  items ReturnItem[]

  @@index([organizationId])
  @@index([orderId])
  @@index([status])
  @@map("returns")
}

model ReturnItem {
  id               String             @id @default(cuid())
  returnId         String
  return           Return             @relation(fields: [returnId], references: [id], onDelete: Cascade)
  /**
   * Snapshot of the returned order line (plain refs, not FKs).
   */
  orderItemId      String
  productVariantId String?
  quantity         Int
  /**
   * Set when the return is processed; null while PENDING.
   */
  disposition      ReturnDisposition?

  @@index([returnId])
  @@map("return_items")
}

enum SalePaymentMethod {
  CASH
  QRIS
  TRANSFER
  CARD
  OTHER
}

enum SaleStatus {
  COMPLETED
  VOID
  /**
   * At least one line has been partially/fully refunded (sale itself stands).
   */
  PARTIALLY_REFUNDED
}

model Sale {
  id             String            @id @default(cuid())
  /**
   * Actor: the kasir who rang it up. Scope queries use organizationId.
   */
  userId         String
  user           User              @relation(fields: [userId], references: [id])
  organizationId String
  organization   Organization      @relation(fields: [organizationId], references: [id])
  /**
   * Readable reference (e.g. S00001), generated per-organization at create.
   */
  code           String
  customerName   String?
  paymentMethod  SalePaymentMethod @default(CASH)
  status         SaleStatus        @default(COMPLETED)
  /**
   * Sum of line gross (qty x unitPrice) before discount/tax. Backfilled = totalAmount for legacy rows.
   */
  subtotalAmount Decimal           @default(0) @db.Decimal(14, 2)
  /**
   * Cart-level discount, resolved to rupiah at checkout (allocated per line on SaleItem).
   */
  discountAmount Decimal           @default(0) @db.Decimal(14, 2)
  /**
   * PPN rate in percent (e.g. 11). 0 = no tax on this sale.
   */
  taxRate        Decimal           @default(0) @db.Decimal(5, 2)
  /**
   * Resolved tax in rupiah (contained in totalAmount when taxInclusive).
   */
  taxAmount      Decimal           @default(0) @db.Decimal(14, 2)
  /**
   * true = prices already contain PPN; false = PPN added on top of the base.
   */
  taxInclusive   Boolean           @default(false)
  /**
   * Amount payable: (subtotal - discount) + tax when exclusive; the base itself when inclusive.
   */
  totalAmount    Decimal           @db.Decimal(14, 2)
  note           String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  items   SaleItem[]
  refunds SaleRefund[]

  @@index([organizationId])
  @@unique([organizationId, code])
  @@map("sales")
}

model SaleItem {
  id               String         @id @default(cuid())
  saleId           String
  sale             Sale           @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productVariantId String
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id])
  /**
   * Snapshot of the variant at sale time, for stable history.
   */
  sku              String
  name             String
  quantity         Int
  unitPrice        Decimal        @db.Decimal(12, 2)
  /**
   * COGS snapshot: the variant's cost at sale time. null = unknown (pre-backfill).
   */
  unitCost         Decimal?       @db.Decimal(12, 2)
  /**
   * This line's share of the cart discount (allocated by gross, largest-remainder).
   */
  discountAmount   Decimal        @default(0) @db.Decimal(12, 2)
  /**
   * Snapshot of the bundle this line came from (null = a standalone variant line).
   */
  bundleName       String?

  refundItems SaleRefundItem[]

  @@index([saleId])
  @@index([productVariantId])
  @@map("sale_items")
}

/**
 * A partial/per-item refund against a counter sale (the sale itself stands).
 */
model SaleRefund {
  id             String        @id @default(cuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id])
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  saleId         String
  sale           Sale          @relation(fields: [saleId], references: [id], onDelete: Cascade)
  /**
   * Readable reference (e.g. RF00001), generated per-user at create.
   */
  code           String
  /**
   * Cash returned to the buyer (sum of line amounts, incl. their PPN share).
   */
  totalAmount    Decimal       @db.Decimal(14, 2)
  note           String?
  createdAt      DateTime      @default(now())

  items SaleRefundItem[]

  @@index([organizationId])
  @@unique([organizationId, code])
  @@index([saleId])
  @@map("sale_refunds")
}

model SaleRefundItem {
  id               String         @id @default(cuid())
  refundId         String
  refund           SaleRefund     @relation(fields: [refundId], references: [id], onDelete: Cascade)
  saleItemId       String
  saleItem         SaleItem       @relation(fields: [saleItemId], references: [id], onDelete: Cascade)
  productVariantId String
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id])
  /**
   * Snapshots at refund time, for stable history.
   */
  sku              String
  name             String
  quantity         Int
  /**
   * Cash refunded for this line: qty x net unit (discount netted, PPN share included).
   */
  amount           Decimal        @db.Decimal(12, 2)

  @@index([refundId])
  @@index([productVariantId])
  @@map("sale_refund_items")
}

enum PurchaseOrderStatus {
  ORDERED // placed with the supplier — units are incoming
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

model PurchaseOrder {
  id             String              @id @default(cuid())
  userId         String
  user           User                @relation(fields: [userId], references: [id])
  organizationId String
  organization   Organization        @relation(fields: [organizationId], references: [id])
  /**
   * Readable reference (e.g. PO00001), generated per-user at create.
   */
  code           String
  supplierName   String?
  status         PurchaseOrderStatus @default(ORDERED)
  note           String?
  totalCost      Decimal             @db.Decimal(14, 2)
  orderedAt      DateTime            @default(now())
  receivedAt     DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  items PurchaseOrderItem[]

  @@index([organizationId])
  @@unique([organizationId, code])
  @@index([status])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id               String         @id @default(cuid())
  purchaseOrderId  String
  purchaseOrder    PurchaseOrder  @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productVariantId String
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id])
  /**
   * Snapshot of the variant at order time, for stable history.
   */
  sku              String
  name             String
  quantity         Int
  receivedQuantity Int            @default(0)
  unitCost         Decimal        @db.Decimal(12, 2)
  /**
   * Snapshot of the bundle this line came from (null = a standalone variant line).
   */
  bundleName       String?

  @@index([purchaseOrderId])
  @@index([productVariantId])
  @@map("purchase_order_items")
}

enum StockOpnameStatus {
  DRAFT // counting in progress
  COMPLETED // posted — variances written to the ledger
  CANCELLED
}

/**
 * A stock-opname (cycle-count) session: a physical count reconciled against the
 * system. Each line snapshots what the system said when the item was added and
 * what was physically counted; posting (COMPLETED) writes the variance to the
 * append-only StockLedger as a RECONCILE row and corrects the Inventory cache.
 */
model StockOpname {
  id             String            @id @default(cuid())
  userId         String
  user           User              @relation(fields: [userId], references: [id])
  organizationId String
  organization   Organization      @relation(fields: [organizationId], references: [id])
  /**
   * Readable reference (e.g. OP00001), generated per-user at create.
   */
  code           String
  status         StockOpnameStatus @default(DRAFT)
  note           String?
  startedAt      DateTime          @default(now())
  completedAt    DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  items StockOpnameItem[]

  @@index([organizationId])
  @@unique([organizationId, code])
  @@index([status])
  @@map("stock_opnames")
}

model StockOpnameItem {
  id               String         @id @default(cuid())
  stockOpnameId    String
  stockOpname      StockOpname    @relation(fields: [stockOpnameId], references: [id], onDelete: Cascade)
  productVariantId String
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id])
  /**
   * Snapshot of the variant at count time, for stable history.
   */
  sku              String
  name             String
  /**
   * Available stock the system showed when this line was added to the count.
   */
  systemQuantity   Int
  countedQuantity  Int
  /**
   * countedQuantity − systemQuantity, stored for stable history + the variance report.
   */
  variance         Int
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([stockOpnameId, productVariantId])
  @@index([stockOpnameId])
  @@index([productVariantId])
  @@map("stock_opname_items")
}
