{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalPassThroughEnv": [
    "NODE_ENV",
    "DATABASE_URL",
    "LOG_LEVEL",
    "REDIS_URL",
    "AUTH_SECRET",
    "AUTH_URL",
    "NEXTAUTH_URL",
    "R2_ACCOUNT_ID",
    "R2_ACCESS_KEY_ID",
    "R2_SECRET_ACCESS_KEY",
    "R2_BUCKET_NAME",
    "R2_PUBLIC_URL",
    "SHOPEE_PARTNER_ID",
    "SHOPEE_PARTNER_KEY",
    "TOKOPEDIA_CLIENT_ID",
    "TOKOPEDIA_CLIENT_SECRET",
    "MARKETPLACE_ENCRYPTION_SECRET",
    "NEXT_PUBLIC_APP_URL",
    "NEXT_PUBLIC_APP_NAME",
    "NEXT_PUBLIC_PAIRING_URL",
    "DEV_HTTPS",
    "PORT",
    "HOSTNAME",
    "PAIRING_LAN_HOST",
    "SEED_ADMIN_EMAIL",
    "SEED_ADMIN_PASSWORD",
    "SEED_DEMO_PASSWORD",
    "NEXT_RUNTIME",
    "SENTRY_DSN",
    "SENTRY_ENVIRONMENT",
    "SENTRY_TRACES_SAMPLE_RATE"
  ],
  "globalEnv": [
    "NODE_ENV",
    "DATABASE_URL",
    "LOG_LEVEL",
    "REDIS_URL",
    "AUTH_SECRET",
    "AUTH_URL",
    "NEXTAUTH_URL",
    "R2_ACCOUNT_ID",
    "R2_ACCESS_KEY_ID",
    "R2_SECRET_ACCESS_KEY",
    "R2_BUCKET_NAME",
    "R2_PUBLIC_URL",
    "SHOPEE_PARTNER_ID",
    "SHOPEE_PARTNER_KEY",
    "TOKOPEDIA_CLIENT_ID",
    "TOKOPEDIA_CLIENT_SECRET",
    "MARKETPLACE_ENCRYPTION_SECRET",
    "NEXT_PUBLIC_APP_URL",
    "NEXT_PUBLIC_APP_NAME",
    "NEXT_PUBLIC_PAIRING_URL",
    "DEV_HTTPS",
    "PORT",
    "HOSTNAME",
    "PAIRING_LAN_HOST",
    "SEED_ADMIN_EMAIL",
    "SEED_ADMIN_PASSWORD",
    "SEED_DEMO_PASSWORD",
    "NEXT_RUNTIME",
    "SENTRY_DSN",
    "SENTRY_ENVIRONMENT",
    "SENTRY_TRACES_SAMPLE_RATE"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "db:generate": {
      "cache": false
    },
    "db:push": {
      "cache": false
    },
    "db:migrate:dev": {
      "cache": false
    },
    "db:migrate:deploy": {
      "cache": false
    },
    "db:migrate:reset": {
      "cache": false
    },
    "db:seed": {
      "cache": false
    },
    "db:studio": {
      "cache": false,
      "persistent": true
    }
  }
}
