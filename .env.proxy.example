# Config for the SHARED Caddy reverse proxy (docker-compose.proxy.yml).
#   cp .env.proxy.example .env.proxy   # then fill the domains
#   docker compose -f docker-compose.proxy.yml --env-file .env.proxy up -d
# Each domain needs a DNS A record → this server's IP before Caddy can issue TLS.

PROD_DOMAIN=palka.app
# Leave empty until you add the staging stack + uncomment the staging block in Caddyfile.
STAGING_DOMAIN=
