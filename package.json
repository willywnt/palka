{
  "name": "falka",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "pnpm --filter @falka/web dev",
    "dev:worker": "pnpm --filter @falka/worker dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,cjs,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,cjs,json,md,css}\"",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "setup": "pnpm infra:up && pnpm infra:wait && pnpm db:setup",
    "infra:up": "node scripts/infra.mjs up",
    "infra:down": "node scripts/infra.mjs down",
    "infra:reset": "node scripts/infra.mjs reset",
    "infra:wait": "node scripts/infra.mjs wait",
    "infra:status": "node scripts/infra.mjs status",
    "db:generate": "pnpm --filter @falka/db db:generate",
    "db:up": "pnpm infra:up",
    "db:down": "pnpm infra:down",
    "db:wait": "pnpm --filter @falka/db db:wait",
    "db:setup": "pnpm --filter @falka/db db:setup",
    "db:push": "pnpm --filter @falka/db db:push",
    "db:migrate:dev": "pnpm --filter @falka/db db:migrate:dev",
    "db:migrate:deploy": "pnpm --filter @falka/db db:migrate:deploy",
    "db:migrate:reset": "pnpm --filter @falka/db db:migrate:reset",
    "db:seed": "pnpm --filter @falka/db db:seed",
    "db:studio": "pnpm --filter @falka/db db:studio",
    "db:reset-demo": "pnpm --filter @falka/db db:reset-demo",
    "lazada:smoke": "pnpm --filter @falka/marketplace-providers build && node scripts/lazada-smoke.mjs",
    "lazada:token": "pnpm --filter @falka/marketplace-providers build && node scripts/lazada-token.mjs",
    "lazada:products": "pnpm --filter @falka/marketplace-providers build && node scripts/lazada-products.mjs",
    "lazada:stock": "pnpm --filter @falka/marketplace-providers build && node scripts/lazada-stock.mjs",
    "lazada:mw-probe": "pnpm --filter @falka/marketplace-providers build && node scripts/lazada-mw-probe.mjs",
    "lazada:seller": "pnpm --filter @falka/marketplace-providers build && node scripts/lazada-seller.mjs",
    "prepare": "node scripts/prepare.mjs"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "turbo": "^2.9.14",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "ioredis": "^5.6.1"
    }
  },
  "dependencies": {
    "@vercel/speed-insights": "^2.0.0"
  }
}
