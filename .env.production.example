# =============================================================================
# Falka — Production environment reference (Vercel + Neon + R2)
# Set these in Vercel Project Settings → Environment Variables
# Do NOT commit real secrets to git
# =============================================================================

NODE_ENV=production
LOG_LEVEL=info

# Neon PostgreSQL (use the POOLED connection string for serverless runtime)
DATABASE_URL=postgresql://USER:PASSWORD@HOST-pooler/falka?sslmode=require
# DIRECT (non-pooled) connection for Prisma migrations — Neon's -pooler (PgBouncer) endpoint
# can't hold the migrate advisory lock (P1002 timeout). Use the host WITHOUT "-pooler".
DIRECT_URL=postgresql://USER:PASSWORD@HOST/falka?sslmode=require

# Redis (Upstash or managed Redis — optional until BullMQ workers are added)
REDIS_URL=redis://default:PASSWORD@HOST:6379

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=https://your-domain.com
NEXTAUTH_URL=https://your-domain.com

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_RECORDINGS_BUCKET_NAME=falka-recordings-prod
# Recordings bucket public base (its own r2.dev/custom domain; objects served at root)
R2_PUBLIC_URL=https://cdn-recordings.your-domain.com
R2_PRODUCTS_BUCKET_NAME=falka-products-prod
# Products bucket public base (its own r2.dev/custom domain; objects served at root)
R2_PRODUCTS_PUBLIC_URL=https://cdn-products.your-domain.com

# Marketplace encryption — generate with: openssl rand -base64 32
MARKETPLACE_ENCRYPTION_SECRET=

# Client (public)
NEXT_PUBLIC_APP_URL=https://your-domain.com
NEXT_PUBLIC_APP_NAME=Falka

# Marketplace OAuth (when enabled)
SHOPEE_PARTNER_ID=
SHOPEE_PARTNER_KEY=
# Lazada Open Platform (real OAuth integration)
LAZADA_APP_KEY=
LAZADA_APP_SECRET=
LAZADA_API_BASE_URL=https://api.lazada.co.id/rest
LAZADA_OAUTH_REDIRECT_URI=https://your-domain.com/api/v1/marketplaces/lazada/oauth/callback
