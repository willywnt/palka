# =============================================================================
# Olshop — Production environment reference (Vercel + Neon + R2)
# Set these in Vercel Project Settings → Environment Variables
# Do NOT commit real secrets to git
# =============================================================================

NODE_ENV=production
LOG_LEVEL=info

# Neon PostgreSQL (use pooled connection string for serverless)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/olshop?sslmode=require

# Redis (Upstash or managed Redis — optional until BullMQ workers are added)
REDIS_URL=redis://default:PASSWORD@HOST:6379

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=https://your-domain.com
NEXTAUTH_URL=https://your-domain.com

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_RECORDINGS_BUCKET_NAME=olshop-recordings-prod
# Recordings bucket public base (its own r2.dev/custom domain; objects served at root)
R2_PUBLIC_URL=https://cdn-recordings.your-domain.com
R2_PRODUCTS_BUCKET_NAME=olshop-products-prod
# Products bucket public base (its own r2.dev/custom domain; objects served at root)
R2_PRODUCTS_PUBLIC_URL=https://cdn-products.your-domain.com

# Marketplace encryption — generate with: openssl rand -base64 32
MARKETPLACE_ENCRYPTION_SECRET=

# Client (public)
NEXT_PUBLIC_APP_URL=https://your-domain.com
NEXT_PUBLIC_APP_NAME=Olshop

# Marketplace OAuth (when enabled)
SHOPEE_PARTNER_ID=
SHOPEE_PARTNER_KEY=
TOKOPEDIA_CLIENT_ID=
TOKOPEDIA_CLIENT_SECRET=
